@model LiveStore.Models.GastoMensalModel
@{ ViewData["Title"] = "Novo Gasto"; }

<div class="container" style="max-width:640px">
    <div class="form-card">
        <div class="mb-3">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
        <div class="text-center mb-4">
            <h2 class="text-white">Novo Gasto</h2>
        </div>

        <form method="post" asp-action="Cadastrar">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Descrição</label>
                <input type="text" class="form-control" asp-for="Descricao" placeholder="Ex: Conta de luz, Fornecedor X..." />
                <span class="text-danger small" asp-validation-for="Descricao"></span>
            </div>

            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Valor (R$)</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-light border-secondary">R$</span>
                    <input type="number" class="form-control" asp-for="Valor" min="0.01" step="0.01" placeholder="0,00" />
                </div>
                <span class="text-danger small" asp-validation-for="Valor"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-light fw-semibold">Data</label>
                <input type="date" class="form-control" asp-for="Data" />
                <span class="text-danger small" asp-validation-for="Data"></span>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-pink w-50">
                    <i class="bi bi-check-circle me-1"></i> Salvar
                </button>
                <a asp-action="Index" class="btn btn-secondary w-50">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
