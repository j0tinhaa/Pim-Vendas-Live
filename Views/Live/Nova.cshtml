@* ============================================================
   Views/Live/Nova.cshtml
   ============================================================ *@
@{  ViewData["Title"] = "Nova Live"; }

<div class="container" style="max-width:560px">
    <div class="form-card">
        <div class="text-center mb-4">
            <div style="font-size:3rem">🎬</div>
            <h2 class="text-white">Iniciar Nova Live</h2>
            <p class="text-muted">Preencha os dados para começar</p>
        </div>

        <form method="post" asp-controller="Live" asp-action="Nova">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Nome da Live</label>
                <input type="text" name="nome" class="form-control"
                       placeholder="Ex: Live de Sábado — Novidades de Verão" required maxlength="100" />
                <span class="text-danger small">@(ViewData.ModelState["nome"]?.Errors.FirstOrDefault()?.ErrorMessage)</span>
            </div>

            <div class="mb-4">
                <label class="form-label text-light fw-semibold">Descrição <span class="text-muted">(opcional)</span></label>
                <textarea name="descricao" class="form-control" rows="2"
                          placeholder="Tema, coleção, promoções do dia..."></textarea>
            </div>

            <div class="alert alert-warning small" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Se houver uma live ativa, ela será encerrada automaticamente ao criar esta.
            </div>

            <div class="d-flex gap-3 mt-3">
                <button type="submit" class="btn btn-pink w-50">
                    <i class="bi bi-camera-video me-1"></i> Iniciar Live
                </button>
                <a asp-controller="Live" asp-action="Ativa" class="btn btn-secondary w-50">Cancelar</a>
            </div>
        </form>
    </div>
</div>
