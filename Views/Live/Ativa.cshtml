@model IEnumerable<LiveStore.Models.VendaModel>
@using LiveStore.Models
@{
    ViewData["Title"] = "Live Ativa";
    var live = (LiveModel)ViewBag.Live;
    int liveId = (int)ViewBag.LiveId;
    var vendas = Model.ToList();
    var faturamento = vendas.Where(v => v.Status != StatusVenda.Cancelado).Sum(v => v.Valor);
}

<div class="container-fluid">

    @* Cabeçalho da live *@
    <div class="live-header mb-4">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <span class="live-dot-lg"></span>
            <div>
                <h1 class="text-white mb-0 fs-3">@live.Nome</h1>
                @if (!string.IsNullOrWhiteSpace(live.Descricao))
                {
                    <small class="text-muted">@live.Descricao</small>
                }
                <br /><small class="text-muted">Iniciada às @live.IniciadaEm.ToString("HH:mm") — @live.IniciadaEm.ToString("dd/MM/yyyy")</small>
            </div>
            <div class="ms-auto d-flex gap-2 flex-wrap">
                <div class="live-stat">
                    <span class="live-stat-val">@vendas.Count</span>
                    <span class="live-stat-label">vendas</span>
                </div>
                <div class="live-stat">
                    <span class="live-stat-val text-success">@faturamento.ToString("C0", new System.Globalization.CultureInfo("pt-BR"))</span>
                    <span class="live-stat-label">faturamento</span>
                </div>
                <a asp-controller="Venda" asp-action="Cadastrar" asp-route-liveId="@liveId"
                   class="btn btn-pink align-self-center">
                    <i class="bi bi-plus-circle me-1"></i> Nova Venda
                </a>
                <button type="button" class="btn btn-outline-danger btn-sm align-self-center" data-bs-toggle="modal" data-bs-target="#encerrarLiveModal">
                    <i class="bi bi-stop-circle"></i> Encerrar
                </button>
            </div>
        </div>
    </div>

    @* Tabela de vendas *@
    <div class="table-responsive">
        <table id="tabelaVendas" class="table-livestore">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Código</th>
                    <th>Produto</th>
                    <th>Valor</th>
                    <th>Horário</th>
                    <th>Status</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in vendas)
                {
                    <tr>
                        <td><span class="text-pink">@(v.Cliente?.Nome ?? v.ClienteInstagramFormatado)</span></td>
                        <td><code>@v.CodigoProduto</code></td>
                        <td>@v.NomeProduto</td>
                        <td>@v.Valor.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</td>
                        <td>@v.DataVenda.ToString("HH:mm")</td>
                        <td>@Html.Raw(BadgeStatus(v.Status))</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-controller="Venda" asp-action="Editar" asp-route-id="@v.Id"
                                   class="btn btn-warning btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-danger btn-sm" title="Excluir"
                                        onclick="confirmarExclusao('/Venda/Excluir', 'Tem certeza que deseja excluir esta venda do produto @v.NomeProduto?', { id: @v.Id, liveId: @liveId })">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!vendas.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bag-x" style="font-size:3rem"></i>
            <p class="mt-2">Nenhuma venda registrada ainda. <a asp-controller="Venda" asp-action="Cadastrar" asp-route-liveId="@liveId">Registrar primeira venda</a></p>
        </div>
    }
</div>

@functions {
    string BadgeStatus(StatusVenda s) => s switch
    {
        StatusVenda.Reservado => "<span class='status-badge badge-reservado'>Reservado</span>",
        StatusVenda.Pago      => "<span class='status-badge badge-pago'>Pago</span>",
        StatusVenda.Entregue  => "<span class='status-badge badge-entregue'>Entregue</span>",
        StatusVenda.Cancelado => "<span class='status-badge badge-cancelado'>Cancelado</span>",
        _                     => ""
    };
}

@* Modal de Encerrar Live *@
<div class="modal fade" id="encerrarLiveModal" tabindex="-1" aria-labelledby="encerrarLiveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:#1a1730; border: 1px solid var(--pink);">
            <div class="modal-header border-0">
                <h5 class="modal-title text-white" id="encerrarLiveModalLabel">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i> Encerrar Live
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-light">
                <p>Tem certeza que deseja encerrar a live <strong>@live.Nome</strong>?</p>
                <p class="small text-muted mb-0">Essa ação impedirá o registro de novas vendas e permitirá o envio dos relatórios finais.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form asp-controller="Live" asp-action="Encerrar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@liveId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-stop-circle me-1"></i> Sim, Encerrar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
