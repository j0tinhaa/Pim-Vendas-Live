<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LiveStore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Darkly.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PimVendas.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link href="https://cdn.datatables.net/v/dt/dt-2.3.7/datatables.min.css" rel="stylesheet"
          integrity="sha384-wCnlGUpaekN+Mtc+qIoipdqIqe2dvC7hWyzVg8wajZ1sxKnVTbnyBd7pyx7JT0Su" crossorigin="anonymous">
</head>

<body>

    <!-- Botão hambúrguer (só mobile) -->
    <button class="btn btn-hamburguer d-md-none m-2" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
    </button>

    <!-- SIDEBAR -->
    <div id="sidebar" class="text-white p-3">

        <!-- Logo -->
        <div class="logo mb-3">
            <img src="/img/icon.png" alt="Logo LiveStore" />
            <span><span class="pim">Live</span> <strong>Store</strong></span>
        </div>
        <hr class="border-secondary" />

        <ul class="nav flex-column">
            <li>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Venda" ? "active" : "")"
                   asp-controller="Venda" asp-action="Index">
                    <i class="bi bi-camera-video"></i> Live Atual
                </a>
            </li>
            <li><a class="nav-link" href="#"><i class="bi bi-bag"></i> Vendas</a></li>
            <li><a class="nav-link" href="#"><i class="bi bi-box"></i> Estoque</a></li>
            <li><a class="nav-link" href="#"><i class="bi bi-people"></i> Clientes</a></li>
            <li><a class="nav-link" href="#"><i class="bi bi-tag"></i> Produtos</a></li>
            <li><a class="nav-link" href="#"><i class="bi bi-bar-chart"></i> Relatórios</a></li>
            <li><a class="nav-link" href="#"><i class="bi bi-gear"></i> Configurações</a></li>
        </ul>
    </div>

    <!-- CONTEÚDO PRINCIPAL -->
    <div class="content p-3 p-md-4">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/v/dt/dt-2.3.7/datatables.min.js"
            integrity="sha384-aQ8I1X2x8U0AR8D7C4Ah0OvZlwMslQdN5YDAQBA56jXrrhcECijs/i7H+5DDrlV1" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
