<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LiveStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link href="https://cdn.datatables.net/v/dt/dt-2.3.7/datatables.min.css" rel="stylesheet">
</head>
<body>

    <!-- Botão hambúrguer (mobile) -->
    <button class="btn-hamburguer d-md-none" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
    </button>

    <!-- SIDEBAR -->
    <nav id="sidebar">
        <div class="logo">
            <img src="/img/icon.png" alt="Logo" onerror="this.style.display='none'" />
            <span><span class="pim">Live</span><strong>Store</strong></span>
        </div>
        <hr class="sidebar-hr" />

        @{
            var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString();
            var action = ViewContext.RouteData.Values["action"]?.ToString();
        }

        <ul class="nav flex-column">
            <li>
                <a class="nav-link @(ctrl == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>

            <div class="nav-section-label">LIVE</div>

            <li>
                <a class="nav-link @(ctrl == "Live" && action == "Ativa" ? "active" : "")"
                   asp-controller="Live" asp-action="Ativa">
                    <i class="bi bi-camera-video-fill text-pink"></i> Live Ativa
                </a>
            </li>
            <li>
                <a class="nav-link @(ctrl == "Live" && action == "Nova" ? "active" : "")"
                   asp-controller="Live" asp-action="Nova">
                    <i class="bi bi-plus-circle"></i> Nova Live
                </a>
            </li>
            <li>
                <a class="nav-link @(ctrl == "Live" && action == "Index" ? "active" : "")"
                   asp-controller="Live" asp-action="Index">
                    <i class="bi bi-collection-play"></i> Histórico de Lives
                </a>
            </li>

            <div class="nav-section-label">CADASTROS</div>

            <li>
                <a class="nav-link @(ctrl == "Produto" ? "active" : "")"
                   asp-controller="Produto" asp-action="Index">
                    <i class="bi bi-tag"></i> Produtos
                </a>
            </li>
            <li>
                <a class="nav-link @(ctrl == "Cliente" ? "active" : "")"
                   asp-controller="Cliente" asp-action="Index">
                    <i class="bi bi-people"></i> Clientes
                </a>
            </li>
        </ul>
    </nav>

    <!-- CONTEÚDO -->
    <div class="content p-3 p-md-4">
        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["MensagemSucesso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["MensagemInfo"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="bi bi-info-circle me-1"></i> @TempData["MensagemInfo"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/v/dt/dt-2.3.7/datatables.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
