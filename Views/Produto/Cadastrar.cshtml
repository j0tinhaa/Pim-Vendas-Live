@* ============================================================
   Views/Produto/Cadastrar.cshtml
   ============================================================ *@
@model LiveStore.Models.ProdutoModel
@{ ViewData["Title"] = "Novo Produto"; }

<div class="container" style="max-width:600px">
    <div class="form-card">
        <div class="text-center mb-4">
            <h2 class="text-white"><i class="bi bi-tag text-pink"></i> Novo Produto</h2>
        </div>

        <form method="post" asp-controller="Produto" asp-action="Cadastrar">
            @Html.AntiForgeryToken()
            @* Código *@
            <div class="mb-3">
                <label asp-for="Codigo" class="form-label text-light fw-semibold"></label>
                <input type="text" class="form-control font-monospace text-uppercase" asp-for="Codigo"
                       placeholder="Ex: ROSA-001" style="letter-spacing:.08em" />
                <span class="text-danger small" asp-validation-for="Codigo"></span>
                <div class="form-text text-muted">Código único anunciado na live</div>
            </div>
            @* Nome *@
            <div class="mb-3">
                <label asp-for="Nome" class="form-label text-light fw-semibold"></label>
                <input type="text" class="form-control" asp-for="Nome" placeholder="Ex: Blusa floral rosa" />
                <span class="text-danger small" asp-validation-for="Nome"></span>
            </div>
            @* Preço *@
            <div class="mb-3">
                <label asp-for="Preco" class="form-label text-light fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-light border-secondary">R$</span>
                    <input type="number" class="form-control" asp-for="Preco" min="0.01" step="0.01" placeholder="0,00" />
                </div>
                <span class="text-danger small" asp-validation-for="Preco"></span>
            </div>
            @* Categorias *@
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="Tipo" class="form-label text-light fw-semibold"></label>
                    <input type="text" class="form-control" asp-for="Tipo" placeholder="Ex: Blusa" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Cor" class="form-label text-light fw-semibold"></label>
                    <input type="text" class="form-control" asp-for="Cor" placeholder="Ex: Rosa" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Tamanho" class="form-label text-light fw-semibold"></label>
                    <input type="text" class="form-control" asp-for="Tamanho" placeholder="Ex: M" />
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-pink w-50">
                    <i class="bi bi-check-circle me-1"></i> Salvar
                </button>
                <a asp-controller="Produto" asp-action="Index" class="btn btn-secondary w-50">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }


