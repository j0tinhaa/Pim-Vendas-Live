@model LiveStore.Models.ClienteModel
@{ ViewData["Title"] = "Editar Cliente"; }

<div class="container" style="max-width:500px">
    <div class="form-card">
        <div class="text-center mb-4">
            <h2 class="text-white"><i class="bi bi-person-circle text-pink"></i> Editar Cliente</h2>
            <p class="text-muted">@Model.InstagramUser</p>
        </div>

        <form method="post" asp-controller="Cliente" asp-action="Editar">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InstagramUser" />

            <div class="mb-3">
                <label asp-for="Nome" class="form-label text-light fw-semibold"></label>
                <input type="text" class="form-control" asp-for="Nome" placeholder="Nome completo (opcional)" />
            </div>

            <div class="mb-4">
                <label asp-for="Telefone" class="form-label text-light fw-semibold"></label>
                <input type="text" class="form-control" asp-for="Telefone" placeholder="(16) 99999-9999 (opcional)" />
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-pink w-50">
                    <i class="bi bi-check-circle me-1"></i> Salvar
                </button>
                <a asp-controller="Cliente" asp-action="Index" class="btn btn-secondary w-50">Cancelar</a>
            </div>
        </form>
    </div>
</div>
