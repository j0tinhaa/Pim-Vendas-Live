@model IEnumerable<LiveStore.Models.ClienteModel>
@{ ViewData["Title"] = "Clientes"; }

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white"><i class="bi bi-people text-pink"></i> Clientes</h1>
    </div>

    <div class="table-responsive">
        <table id="tabelaClientes" class="table-livestore">
            <thead>
                <tr>
                    <th>Instagram</th>
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>Cadastrado em</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            <span class="text-pink fw-bold">
                                @c.ClienteInstagramFormatado
                            </span>
                        </td>

                        <td>
                            @if (!string.IsNullOrWhiteSpace(c.Nome))
                            {
                                @c.Nome
                            }
                            else
                            {
                                <em class="text-muted">não informado</em>
                            }
                        </td>
                        <td>@(c.Telefone ?? "—")</td>
                        <td>@c.CriadoEm.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a asp-controller="Cliente" asp-action="Editar" asp-route-id="@c.InstagramUser"
                               class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
