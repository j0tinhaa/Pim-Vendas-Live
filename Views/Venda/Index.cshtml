@model IEnumerable<LiveStore.Models.VendaModel>
@using LiveStore.Models

@{
    ViewData["Title"] = "Live Atual";
}

<div class="container-fluid">

    <!-- Cabeçalho -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="text-white mb-0"><i class="bi bi-camera-video text-pink me-2"></i>Live Atual</h1>
            <small class="text-muted">Registre as vendas em tempo real durante a transmissão</small>
        </div>
        <a class="btn btn-success" asp-controller="Venda" asp-action="Cadastrar">
            <i class="bi bi-plus-circle me-1"></i> Nova Venda
        </a>
    </div>

    <!-- Alerta de sucesso -->
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["MensagemSucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabela -->
    <div class="table-responsive">
        <table id="tabelaVendas" class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Código</th>
                    <th>Produto</th>
                    <th>Valor</th>
                    <th>Data da Venda</th>
                    <th>Status</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var venda in Model)
                    {
                        <tr>
                            <td>@venda.Cliente</td>
                            <td><code class="text-pink">@venda.CodigoProduto</code></td>
                            <td>@venda.Produto</td>
                            <td>@venda.Valor.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</td>
                            <td>@venda.DataVenda.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @{
                                    var (badgeClass, badgeText) = venda.Status switch
                                    {
                                        StatusVenda.Pendente  => ("badge-pendente",  "Pendente"),
                                        StatusVenda.Pago      => ("badge-pago",      "Pago"),
                                        StatusVenda.Cancelado => ("badge-cancelado", "Cancelado"),
                                        StatusVenda.Entregue  => ("badge-entregue",  "Entregue"),
                                        _                     => ("badge-pendente",  "Pendente")
                                    };
                                }
                                <span class="status-badge @badgeClass">@badgeText</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1 flex-wrap">
                                    <a asp-controller="Venda" asp-action="Editar" asp-route-id="@venda.Id"
                                       class="btn btn-warning btn-sm" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-controller="Venda" asp-action="Excluir" asp-route-id="@venda.Id"
                                       class="btn btn-danger btn-sm" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .text-pink { color: #fa6b9a; }
</style>
