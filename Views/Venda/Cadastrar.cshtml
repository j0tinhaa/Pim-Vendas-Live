@* ============================================================
   Views/Venda/Cadastrar.cshtml
   ============================================================ *@
@model LiveStore.Services.Interfaces.NovaVendaInput
@using LiveStore.Models
@{
    ViewData["Title"] = "Nova Venda";
    var live = (LiveModel)ViewBag.Live;
}

<div class="container" style="max-width:640px">
    <div class="form-card">
        <div class="mb-3">
            <a asp-controller="Live" asp-action="Ativa" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar para live
            </a>
        </div>
        <div class="text-center mb-4">
            <h2 class="text-white">Nova Venda</h2>
            <small class="text-muted">Live: <strong class="text-pink">@live.Nome</strong></small>
        </div>

        <form method="post" asp-controller="Venda" asp-action="Cadastrar" id="formVenda">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="LiveId" />

            @* @ Instagram *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Instagram da Cliente</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-pink border-secondary"></span>
                    <input type="text" class="form-control" asp-for="ClienteInstagram"
                           placeholder="nome_da_cliente" autocomplete="off" />
                </div>
                <span class="text-danger small" asp-validation-for="ClienteInstagram"></span>
                <div class="form-text text-muted">Se a cliente não existir, será cadastrada automaticamente.</div>
            </div>

            @* Código do produto *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Código do Produto</label>
                <div class="input-group">
                    <input type="text" class="form-control font-monospace text-uppercase" asp-for="CodigoProduto"
                           placeholder="Ex: ROSA-001" autocomplete="off" />
                    <button type="button" class="btn btn-outline-secondary" id="btnBuscarProduto" title="Buscar Produto">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
                <span class="text-danger small" asp-validation-for="CodigoProduto"></span>
                <div id="produtoFeedback" class="form-text"></div>
            </div>

            @* Nome do produto *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Nome do Produto</label>
                <input type="text" class="form-control" asp-for="NomeProduto"
                       placeholder="Ex: Blusa floral rosa P" />
                <span class="text-danger small" asp-validation-for="NomeProduto"></span>
            </div>

            @* Valor *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Valor (R$)</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-light border-secondary">R$</span>
                    <input type="number" class="form-control" asp-for="Valor"
                           min="0.01" step="0.01" placeholder="0,00" />
                </div>
                <span class="text-danger small" asp-validation-for="Valor"></span>
            </div>

            @* Status *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Status</label>
                <select class="form-select" asp-for="Status"
                        asp-items="Html.GetEnumSelectList<LiveStore.Models.StatusVenda>()"></select>
            </div>

            @* Observações *@
            <div class="mb-4">
                <label class="form-label text-light fw-semibold">Observações <small class="text-muted">(opcional)</small></label>
                <textarea class="form-control" asp-for="Observacoes" rows="2"
                          placeholder="Endereço, forma de pagamento, tamanho..."></textarea>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-pink w-50">
                    <i class="bi bi-check-circle me-1"></i> Registrar Venda
                </button>
                <a asp-controller="Live" asp-action="Ativa" class="btn btn-secondary w-50">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function() {
            function buscarProdutoManualmente() {
                const codigo = $('#CodigoProduto').val().trim();
                if (!codigo) return;

                $.get('/Venda/BuscarProduto', { codigo: codigo })
                    .done(function(p) {
                        $('#NomeProduto').val(p.nome);
                        // Ajusta o valor para o formato numérico sem formatação string local do pt-BR para o input number
                        $('#Valor').val(p.preco.toFixed(2).replace('.', ','));
                        $('#produtoFeedback').html(`<span class="text-success"><i class="bi bi-check-circle"></i> Produto encontrado: <strong>${p.nome}</strong></span>`);
                    })
                    .fail(function() {
                        $('#produtoFeedback').html(`<span class="text-warning"><i class="bi bi-exclamation-circle"></i> Código não encontrado. Preencha manualmente.</span>`);
                    });
            }

            $('#btnBuscarProduto').on('click', buscarProdutoManualmente);

            $('#CodigoProduto').on('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    buscarProdutoManualmente();
                }
            });
            
            // Impede que o form seja submetido se o usuário apertar Enter em qualquer lugar além do botão submit (opcional, já tratado acima para o CodigoProduto)
        });
    </script>
}
