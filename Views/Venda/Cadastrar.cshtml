@* ============================================================
   Views/Venda/Cadastrar.cshtml
   ============================================================ *@
@model LiveStore.Services.Interfaces.NovaVendaInput
@using LiveStore.Models
@{
    ViewData["Title"] = "Nova Venda";
    var live = (LiveModel)ViewBag.Live;
}

<div class="container" style="max-width:640px">
    <div class="form-card">
        <div class="mb-3">
            <a asp-controller="Live" asp-action="Ativa" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar para live
            </a>
        </div>
        <div class="text-center mb-4">
            <h2 class="text-white">Nova Venda</h2>
            <small class="text-muted">Live: <strong class="text-pink">@live.Nome</strong></small>
        </div>

        <form method="post" asp-controller="Venda" asp-action="Cadastrar" id="formVenda">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="LiveId" />

            @* @ Instagram *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Instagram da Cliente</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-pink border-secondary"></span>
                    <input type="text" class="form-control" asp-for="ClienteInstagram"
                           placeholder="nome_da_cliente" autocomplete="off" />
                </div>
                <span class="text-danger small" asp-validation-for="ClienteInstagram"></span>
                <div class="form-text text-muted">Se a cliente não existir, será cadastrada automaticamente.</div>
            </div>

            @* Código *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Código</label>
                <input type="text" class="form-control font-monospace text-uppercase" asp-for="Codigo"
                       placeholder="Ex: brilho" autocomplete="off" />
                <span class="text-danger small" asp-validation-for="Codigo"></span>
                <div class="form-text text-muted">Código único dentro desta live.</div>
            </div>

            @* Nome *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Nome do Produto</label>
                <input type="text" class="form-control" asp-for="Nome"
                       placeholder="Ex: Blusa floral rosa P" />
                <span class="text-danger small" asp-validation-for="Nome"></span>
            </div>

            @* Descrição *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Descrição <small class="text-muted">(opcional)</small></label>
                <textarea class="form-control" asp-for="Descricao" rows="2"
                          placeholder="Cor, tamanho, detalhes..."></textarea>
                <span class="text-danger small" asp-validation-for="Descricao"></span>
            </div>

            @* Valor *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Valor (R$)</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-light border-secondary">R$</span>
                    <input type="number" class="form-control" asp-for="Valor"
                           min="0.01" step="0.01" placeholder="0,00" />
                </div>
                <span class="text-danger small" asp-validation-for="Valor"></span>
            </div>

            @* Status *@
            <div class="mb-3">
                <label class="form-label text-light fw-semibold">Status</label>
                <select class="form-select" asp-for="Status"
                        asp-items="Html.GetEnumSelectList<LiveStore.Models.StatusVenda>()"></select>
            </div>

            @* Observações *@
            <div class="mb-4">
                <label class="form-label text-light fw-semibold">Observações <small class="text-muted">(opcional)</small></label>
                <textarea class="form-control" asp-for="Observacoes" rows="2"
                          placeholder="Endereço, forma de pagamento..."></textarea>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-pink w-50">
                    <i class="bi bi-check-circle me-1"></i> Registrar Venda
                </button>
                <a asp-controller="Live" asp-action="Ativa" class="btn btn-secondary w-50">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
